{
  "name": "echo-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js",
    "build:vercel": "esbuild api/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=api/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.105.3",
    "hono": "^4.7.10",
    "resend": "^4.5.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "esbuild": "^0.25.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
