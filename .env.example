PORT=3000

# Supabase (Settings > API Keys — use new opaque key format)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx   # replaces anon key; safe for client use, subject to RLS
SUPABASE_SECRET_KEY=sb_secret_xxxx             # replaces service_role key; bypasses RLS — server only

# Resend
RESEND_API_KEY=re_your_api_key
