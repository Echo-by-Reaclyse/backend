PORT=3000

# Neon DB (Settings > Connection string)
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_WAITLIST_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RESEND_APP_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Slack incoming webhook URLs (Settings > Incoming Webhooks in your Slack app)
SLACK_WAITLIST_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_OAUTH_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
